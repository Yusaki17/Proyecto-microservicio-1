# Configuración de MySQL
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=customer_db      # ← igual a CUSTOMER_DB_NAME
MYSQL_USER=usuario
MYSQL_PASSWORD=password
MYSQL_PORT=3306

# Configuración de Oracle
ORACLE_USERNAME=system
ORACLE_PWD=tu_password
ORACLE_PORT=1522

# Configuración de la base de datos PostgreSQL
POSTGRESQL_DB_USERNAME=root
POSTGRESQL_DB_PASSWORD=pass
POSTGRESQL_DB_PORT=5432

# Configuración del Config Server
CONFIG_SERVER_PORT=8888

# Configuración del Eureka Server
EUREKA_SERVER_PORT=8761

# Configuración del Customer Microservice
CUSTOMER_DB_NAME=customer_db    # ← igual a MYSQL_DATABASE
CUSTOMER_MICROSERVICE_PORT=8091

# Configuración del Product Microservice
PRODUCT_DB_NAME=XEPDB1          # ← PDB por defecto de Oracle XE (no product_db)
PRODUCT_MICROSERVICE_PORT=8092

# Configuración del Cart Microservice
CART_DB_NAME=cart_db
CART_MICROSERVICE_PORT=8093

# Configuracion del Api Gateway
API_GATEWAY_PORT=8222
